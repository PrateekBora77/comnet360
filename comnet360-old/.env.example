# ── Database ──────────────────────────────────────────────────────────────────
# MySQL root password used by all 6 microservices
DB_PASSWORD=your_mysql_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be identical across gateway + all 6 services (min 256-bit / 32 chars)
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_characters_long

# ── Email (notification-service SMTP) ─────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here

# ── Internal service URLs ──────────────────────────────────────────────────────
# Only needed if running without Eureka (e.g. plain Docker without service discovery)
NOTIFICATION_SERVICE_URL=http://localhost:8086
